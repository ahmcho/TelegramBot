{
    "name": "ahmcho/telegram",
    "description": "Modern PHP 8.1+ Telegram Bot Framework with zero dependencies, service-oriented architecture, and production-ready features",
    "type": "library",
    "keywords": [
        "telegram",
        "bot",
        "api",
        "framework",
        "php",
        "telegram-bot",
        "telegram-api",
        "messaging",
        "chatbot",
        "bulk-messaging",
        "webhook",
        "commands",
        "retry",
        "rate-limit"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "AhmCho",
            "email": "contact@example.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "AhmCho\\Telegram\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AhmCho\\Telegram\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "analyze": "phpstan analyse",
        "lint": "phpcs --standard=PSR12 src/",
        "lint-fix": "phpcbf --standard=PSR12 src/",
        "quality": [
            "@analyze",
            "@lint"
        ]
    },
    "scripts-descriptions": {
        "test": "Run all tests with PHPUnit",
        "test-coverage": "Run tests with HTML coverage report",
        "analyze": "Run static analysis with PHPStan",
        "lint": "Check code style with PHPCS",
        "lint-fix": "Fix code style issues automatically",
        "quality": "Run all quality checks (analyze + lint)"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
