# Telegram Bot Configuration
# Copy this file to .env and fill in your actual bot token

# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# SSL verification (default: true in production)
# Set to false only for local development against self-signed certs
# TELEGRAM_VERIFY_SSL=false

# Webhook configuration
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook.php

# Webhook secret token — strongly recommended for production
# Set this and pass the same value when calling setWebhook (secret_token param)
# The endpoint returns 403 to any request that doesn't carry this token
TELEGRAM_WEBHOOK_SECRET=your_secret_token_here
